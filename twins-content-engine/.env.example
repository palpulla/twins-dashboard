# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Required: Anthropic API key for Claude calls.
# Create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# GHL (GoHighLevel / DUNZO whitelabel) publishing.
# Get the token under Settings → Private Integrations in your DUNZO sub-account.
# Required scopes: social-media-posting/*.readonly, social-media-posting/*.write
GHL_API_TOKEN=pit-...
GHL_LOCATION_ID=iRUlbIBg7PzSfLrPiR2j
GHL_API_BASE=https://services.leadconnectorhq.com
