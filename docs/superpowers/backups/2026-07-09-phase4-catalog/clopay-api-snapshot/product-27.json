rand Harbor GRLA1"},{"Title":"XA24*","GroupName":"WINDOW DESIGNS","ThumbnailImage":"https://www.clopaydoor.com/images/default-source/product-images/top-sections/grandharbor/gh-xa24.webp?sfvrsn=89142d1d_1","AlternativeText":"XA24","Description":"Grand Harbor XA24"},{"Title":"XG14*","GroupName":"Window Designs","ThumbnailImage":"https://www.clopaydoor.com/images/default-source/product-images/top-sections/grandharbor/gh-xg14.webp?sfvrsn=aac8af61_1","AlternativeText":"XG14","Description":"Grand Harbor XG14"},{"Title":"XG24*","GroupName":"WINDOW DESIGNS","ThumbnailImage":"https://www.clopaydoor.com/images/default-source/product-images/top-sections/grandharbor/gh-xg24.webp?sfvrsn=8d672639_1","AlternativeText":"XG24","Description":"Grand Harbor XG24"},{"Title":"Wrought Iron Short","GroupName":"Window Designs","ThumbnailImage":"https://www.clopaydoor.com/images/default-source/product-images/top-sections/grandharbor/gh-wis.webp?sfvrsn=a51de388_1","AlternativeText":"WROUGHT IRON SHORT","Description":"Grand Harbor WROUGHT IRON SHORT"},{"Title":"Wrought Iron Long","GroupName":"Window Designs","ThumbnailImage":"https://www.clopaydoor.com/images/default-source/product-images/top-sections/grandharbor/gh-wil.webp?sfvrsn=c61d3ba9_1","AlternativeText":"WROUGHT IRON LONG","Description":"Grand Harbor WROUGHT IRON LONG"}],"ProductDesigns":[{"Title":"Design 11","GroupName":"Series 1","ProductImage":"https://www.clopaydoor.com/images/default-source/product-images/product-designs/grandharbor/grand-harbor-design-11.webp?sfvrsn=fa25d803_2","Description":"Grand Harbor - Design11","AlternativeText":"Design 11"},{"Title":"Design 31","GroupName":"Series 3","ProductImage":"https://www.clopaydoor.com/images/default-source/product-images/product-designs/grandharbor/grand-harbor-design-31.webp?sfvrsn=6c058f8_2","Description":"Grand Harbor- Design 31","AlternativeText":"Design 31"},{"Title":"Design 12","GroupName":"Series 1","ProductImage":"https://www.clopaydoor.com/images/default-source/product-ima